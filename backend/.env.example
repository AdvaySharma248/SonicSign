NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
MONGO_URI=mongodb://127.0.0.1:27017/sonicsign
JWT_ACCESS_SECRET=replace-with-a-long-random-value
JWT_REFRESH_SECRET=replace-with-a-different-long-random-value
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
REFRESH_COOKIE_NAME=sonicsign_refresh
UPLOAD_DIR=src/uploads
MAX_UPLOAD_BYTES=10485760
SIGNING_LINK_TTL_HOURS=72
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=SonicSign
SMTP_FROM_EMAIL=no-reply@sonicsign.local
# Legacy format is also supported:
# MAIL_FROM=SonicSign <no-reply@sonicsign.local>

# Firebase Configuration
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
